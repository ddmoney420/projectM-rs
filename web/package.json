{
  "name": "pm-web-ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Browser UI for the projectM-rs WebGPU/WASM visualizer",
  "scripts": {
    "wasm:dev": "wasm-pack build ../crates/pm-web --target web --out-dir ../../web/src/pm_web --dev",
    "wasm:release": "wasm-pack build ../crates/pm-web --target web --out-dir ../../web/src/pm_web --release",
    "dev": "npm run wasm:dev && vite",
    "build": "npm run wasm:release && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
