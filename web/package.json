{
  "name": "pm-web-ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Browser UI for the projectM-rs WebGPU/WASM visualizer",
  "scripts": {
    "wasm:dev": "wasm-pack build ../crates/pm-web --target web --out-dir ../../web/src/pm_web --dev",
    "wasm:release": "wasm-pack build ../crates/pm-web --target web --out-dir ../../web/src/pm_web --release",
    "dev": "npm run wasm:dev && vite",
    "build": "npm run wasm:release && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-cpp": "^6.0.2",
    "@codemirror/language": "^6.10.0",
    "@codemirror/lint": "^6.8.0",
    "@codemirror/search": "^6.5.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/theme-one-dark": "^6.1.0",
    "@codemirror/view": "^6.28.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
